{
  "name": "coupons",
  "version": "1.0.0",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "docker:start": "open -a Docker",
    "docker:wait": "sh -c 'until docker info >/dev/null 2>&1; do echo \"Waiting for Docker daemon...\"; sleep 2; done; echo \"Docker is ready.\"'",
    "monitoring:up:auto": "npm run docker:start && npm run docker:wait && npm run monitoring:up",
    "monitoring:up": "docker compose -f docker-compose.monitoring.yml up -d",
    "monitoring:down": "docker compose -f docker-compose.monitoring.yml down"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "prisma": "^7.5.0",
    "prom-client": "^15.1.3",
    "sequelize": "^6.37.8",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
